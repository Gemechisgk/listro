rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().email == request.auth.token.email
        && incoming().createdAt is string; // Initial sync
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'loyaltyPoints']);
    }

    // Order rules
    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && incoming().quantity is number 
        && incoming().quantity > 0;
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && (
          // Allow cancelling or updating details while pending or adding payment info
          (existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasAny(['services', 'customService', 'quantity', 'logistics', 'address', 'location', 'status', 'updatedAt', 'estimatedCost', 'discountApplied', 'pointsEarned', 'paymentStatus', 'tx_ref', 'shoeImages']))
          // Allow submitting reviews on completed orders
          || (existing().status == 'completed' && incoming().diff(existing()).affectedKeys().hasAny(['rating', 'review', 'updatedAt']))
          // Allow cancellation
          || (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'cancelled')
        );
    }
  }
}
